# ─── FRONTEND PUBLIC ENV VARS ────────────────────────────────────────────────
# Variables prefixed with VITE_ are exposed to the browser.
# NEVER place secrets, keys, or tokens here.

# Example: VITE_API_BASE_URL=https://your-backend.vercel.app
VITE_API_BASE_URL=http://localhost:8000

# App metadata
VITE_APP_NAME=CrediClear
VITE_APP_VERSION=1.0.0
